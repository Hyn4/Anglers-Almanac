$Common = "Common.ui";

@TrackTex = PatchStyle(TexturePath: "slider_track.png");
@ZoneTex = PatchStyle(TexturePath: "slider_zone.png");
@MarkerTex = PatchStyle(TexturePath: "SkillCheck_marker (Custom).png");


Group #DialContainer {
  Anchor: (Width: 600, Height: 60);

  // 1. The Track (Bottom Layer)
  Group #Track {
    Background: @TrackTex;
  }

  // 2. The Success Zone (Middle Layer)
  Group #GreenZone {
    Background: @ZoneTex;
    // Width and Height are fixed; Left is set by Java
    Anchor: (Width: 60, Height: 60, Left: 0);
  }

  // 3. The Marker (Top Layer)
  Group #Marker {
    Background: @MarkerTex;
    // Marker is slightly wider or different color to stand out
    Anchor: (Width: 70, Height: 60, Left: 0);
  }
}